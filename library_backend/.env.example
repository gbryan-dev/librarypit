# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True

# React frontend URL (verification links open this site)
FRONTEND_URL=http://localhost:5173

# Email verification on signup / login
REQUIRE_EMAIL_VERIFICATION=True

# --- Option A: Development (emails print in Django terminal, not real inbox) ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# --- Option B: Real emails via Gmail (recommended for production) ---
# To send real verification emails, comment out the console backend above
# and provide your Gmail SMTP settings below.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-gmail-app-password
# DEFAULT_FROM_EMAIL=Library System <your-email@gmail.com>
#
# Gmail requires an App Password (Google Account → Security → 2-Step Verification → App passwords)
# Use the App Password as EMAIL_HOST_PASSWORD. Regular Gmail passwords are usually rejected for SMTP.
